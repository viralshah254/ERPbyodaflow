# Backend API base URL. When set, the frontend calls real endpoints; when unset, mocks are used.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_RUNTIME_MODE=live

# Set to true only when testing Copilot UI locally without org featureFlags.copilot.
# NEXT_PUBLIC_COPILOT_ENABLED=true

# Explicit local developer access. These must be enabled before any dev headers are sent.
NEXT_PUBLIC_ENABLE_DEV_AUTH=0
NEXT_PUBLIC_ENABLE_MOCK_AUTH=0
NEXT_PUBLIC_ENABLE_DEV_PAGES=0

# Option A – Demo mode (local demos only): set to 1 only when you intentionally want seeded demo users.
NEXT_PUBLIC_API_DEMO_MODE=0

# Option B – Dev headers (when not using demo mode): identify user and branch.
NEXT_PUBLIC_DEV_USER_ID=
NEXT_PUBLIC_CURRENT_BRANCH_ID=

# Firebase (erp-odaflow web app) — same project as mobile push / google-services.json
# apiKey: Firebase Console → erp-odaflow → Project settings → Your apps → Web → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=erp-odaflow.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=erp-odaflow
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=erp-odaflow.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=881360318572
NEXT_PUBLIC_FIREBASE_APP_ID=1:881360318572:web:9159355b2304edc797e849
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-VYR6KKQPQR

# Optional — inbox for privacy and account deletion requests (/privacypolicy, /deleteaccount mail-to flow).
# NEXT_PUBLIC_PRIVACY_EMAIL=privacy@example.com
