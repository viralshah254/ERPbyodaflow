# Backend API base URL. When set, the frontend calls real endpoints; when unset, mocks are used.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Option A – Demo mode (simplest for local): backend uses seeded user automatically.
NEXT_PUBLIC_API_DEMO_MODE=1

# Option B – Dev headers (when not using demo mode): identify user and branch.
NEXT_PUBLIC_DEV_USER_ID=d6afe653-c306-4c57-9b97-6bf08a81b2f6
NEXT_PUBLIC_CURRENT_BRANCH_ID=5a59d39c-90b1-46ba-9f56-97f466c7aa5d

# Firebase (for real login). From Firebase Console → Project settings → Your apps → Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
